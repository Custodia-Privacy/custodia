# ===========================================
# Custodia Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# Database (PostgreSQL)
# For production: always use SSL. Append ?sslmode=require (or sslmode=verify-full for strict CA verification)
# Example: postgresql://user:password@db-host:5432/custodia?schema=public&sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/custodia?schema=public"

# Auth (NextAuth.js v5)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_GROWTH_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""

# Seed script: attach demo rows to an existing user (sign up first)
SEED_USER_EMAIL=""

# AI Provider — set ANTHROPIC_API_KEY for Anthropic (default), or AI_API_KEY + AI_BASE_URL for any OpenAI-compatible provider
ANTHROPIC_API_KEY=""
# AI_API_KEY=""           # Alternative: any OpenAI-compatible API key
# AI_BASE_URL=""          # Alternative: OpenAI-compatible base URL (e.g. https://api.openai.com/v1)
# AI_MODEL=""             # Override model name (default: claude-sonnet-4-20250514)

# Cron authentication
CRON_SECRET=""

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Email (Resend) — get a key at resend.com; put the real value in .env.local ONLY (never commit)
RESEND_API_KEY=""

# Geolocation (MaxMind GeoIP)
MAXMIND_LICENSE_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BANNER_CDN_URL="http://localhost:3000/api/banner"
# Health check (no auth): GET {NEXT_PUBLIC_APP_URL}/api/health — use for load balancers; returns 503 if DB is down

# Field-level encryption for PII (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=""

# Nango (integration OAuth management) — self-hosted or cloud
# NANGO_SECRET_KEY=""
# NANGO_HOST="http://localhost:3003"

# Dev-only: verbose tRPC client logs (otherwise Next/Turbopack may show them as console noise)
# NEXT_PUBLIC_VERBOSE_TRPC="true"

# Sentry error monitoring — leave blank locally to disable Sentry entirely.
# Get values from https://sentry.io after creating a Next.js project.
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser (that's expected for DSNs).
NEXT_PUBLIC_SENTRY_DSN=""
# Server-side DSN (optional — falls back to NEXT_PUBLIC_SENTRY_DSN if unset).
SENTRY_DSN=""
# Required ONLY for production builds that upload source maps. Leave blank in dev.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
# Optional release tag. Recommended: set to the git SHA at build time.
# SENTRY_RELEASE=""
# NEXT_PUBLIC_SENTRY_RELEASE=""
