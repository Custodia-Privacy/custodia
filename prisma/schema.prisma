generator client {
  provider = "prisma-client-js"
}

// Production: ensure DATABASE_URL includes ?sslmode=require (or verify-full)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  name            String?   @db.VarChar(255)
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  emailVerifiedAt DateTime? @map("email_verified_at")
  image           String?
  /// In-app email notification toggles: { weeklyScanReports, newTrackerAlerts, dsarDeadlines, policyUpdates }
  notificationSettings Json? @map("notification_settings")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  memberships OrgMember[]
  accounts    Account[]
  sessions    Session[]
  auditLogs   AuditLog[]

  /// PIAs assigned to this user for review / ownership
  assignedAssessments  Assessment[]         @relation("AssessmentAssignee")
  assessmentActivities AssessmentActivity[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @map("provider_account_id") @db.VarChar(255)
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type") @db.VarChar(50)
  scope             String?
  idToken           String? @map("id_token")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Organization ────────────────────────────────────────────────────────────

enum Plan {
  free
  starter
  growth
  business
}

enum OrgRole {
  owner
  admin
  member
}

model Organization {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(255)
  slug                 String   @unique @db.VarChar(100)
  plan                 Plan     @default(free)
  stripeCustomerId     String?  @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id") @db.VarChar(255)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Public branding for white-labeled DSR forms and portals
  brandName     String?  @map("brand_name") @db.VarChar(255)
  brandLogoUrl  String?  @map("brand_logo_url") @db.VarChar(2048)
  brandColor    String?  @map("brand_color") @db.VarChar(7) // hex e.g. #4f46e5
  brandWebsite  String?  @map("brand_website") @db.VarChar(2048)

  members           OrgMember[]
  sites             Site[]
  alerts            Alert[]
  dsarRequests      DsarRequest[]
  assessments       Assessment[]
  dataStores        DataStore[]
  dataFlows         DataFlow[]
  vendors           Vendor[]
  preferenceCenters PreferenceCenter[]
  agentRuns              AgentRun[]
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  webhookSubscriptions   WebhookSubscription[]
  integrations           Integration[]

  @@map("organizations")
}

/// Org-scoped audit trail (assistant confirmations, future admin actions).
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  action       String   @db.VarChar(100)
  source       String   @default("assistant") @db.VarChar(50)
  payload      Json?
  success      Boolean  @default(true)
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model OrgMember {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      OrgRole  @default(member)
  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

// ─── API Keys (for MCP server & agent auth) ─────────────────────────────────

model ApiKey {
  id        String    @id @default(uuid()) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  name      String    @db.VarChar(255)
  keyHash   String    @unique @map("key_hash") @db.VarChar(255)
  prefix    String    @db.VarChar(10)
  scopes    String[]
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── Sites & Scanning ────────────────────────────────────────────────────────

enum ScanFrequency {
  daily
  weekly
  monthly
}

model Site {
  id                String        @id @default(uuid()) @db.Uuid
  orgId             String        @map("org_id") @db.Uuid
  domain            String        @db.VarChar(255)
  name              String        @db.VarChar(255)
  verified          Boolean       @default(false)
  monitoringEnabled Boolean       @default(true) @map("monitoring_enabled")
  scanFrequency     ScanFrequency @default(weekly) @map("scan_frequency")
  lastScannedAt     DateTime?     @map("last_scanned_at")
  complianceScore   Int?          @map("compliance_score")
  deletedAt         DateTime?     @map("deleted_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  /// Optional HTTPS URL for consent/banner events (HMAC-signed POST JSON).
  privacyWebhookUrl    String? @map("privacy_webhook_url") @db.VarChar(2048)
  privacyWebhookSecret String? @map("privacy_webhook_secret") @db.VarChar(255)

  /// JSON config for public-facing policy page styling
  policyPageStyle      Json?   @map("policy_page_style")

  org              Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scans            Scan[]
  findings         Finding[]
  banner           Banner?
  policies         Policy[]
  consentLogs      ConsentLog[]
  alerts           Alert[]
  dsarRequests     DsarRequest[]
  preferenceCenters PreferenceCenter[]

  @@unique([orgId, domain])
  @@map("sites")
}

enum ScanStatus {
  queued
  running
  completed
  failed
}

enum ScanType {
  full
  quick
  monitoring
}

model Scan {
  id               String     @id @default(uuid()) @db.Uuid
  siteId           String     @map("site_id") @db.Uuid
  status           ScanStatus @default(queued)
  scanType         ScanType   @default(full) @map("scan_type")
  pagesCrawled     Int        @default(0) @map("pages_crawled")
  startedAt        DateTime?  @map("started_at")
  completedAt      DateTime?  @map("completed_at")
  summary          Json?
  rawData          Json?      @map("raw_data")
  complianceScores Json?      @map("compliance_scores")
  errorMessage     String?    @map("error_message")
  createdAt        DateTime   @default(now()) @map("created_at")

  site           Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  findings       Finding[]
  policies       Policy[]
  policyVersions PolicyVersion[]

  @@index([siteId, createdAt(sort: Desc)])
  @@map("scans")
}

enum FindingCategory {
  cookie
  tracker
  script
  data_collection
  consent
  policy
}

enum Severity {
  critical
  warning
  info
  ok
}

model Finding {
  id             String          @id @default(uuid()) @db.Uuid
  scanId         String          @map("scan_id") @db.Uuid
  siteId         String          @map("site_id") @db.Uuid
  category       FindingCategory
  severity       Severity
  title          String          @db.VarChar(500)
  description    String
  recommendation String?
  details        Json?
  regulations    String[]
  pageUrl        String?         @map("page_url")
  firstSeenAt    DateTime        @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime        @default(now()) @map("last_seen_at")
  resolvedAt     DateTime?       @map("resolved_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, category])
  @@index([siteId, severity])
  @@map("findings")
}

// ─── Banner & Consent ────────────────────────────────────────────────────────

model Banner {
  id              String    @id @default(uuid()) @db.Uuid
  siteId          String    @unique @map("site_id") @db.Uuid
  enabled         Boolean   @default(false)
  config          Json      @default("{}")
  publishedConfig Json?     @map("published_config")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("banners")
}

enum ConsentAction {
  accept_all
  reject_all
  customize
  dismiss
}

model ConsentLog {
  id           String        @id @default(uuid()) @db.Uuid
  siteId       String        @map("site_id") @db.Uuid
  visitorId    String        @map("visitor_id") @db.VarChar(255)
  ipCountry    String?       @map("ip_country") @db.VarChar(2)
  jurisdiction String?       @db.VarChar(20)
  consentGiven Json          @map("consent_given")
  action       ConsentAction
  userAgent    String?       @map("user_agent")
  createdAt    DateTime      @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt(sort: Desc)])
  @@map("consent_logs")
}

// ─── Privacy Policy ──────────────────────────────────────────────────────────

enum PolicyType {
  privacy_policy
  cookie_policy
  terms_of_service
  acceptable_use
  data_processing
  custom
}

model Policy {
  id              String     @id @default(uuid()) @db.Uuid
  siteId          String     @map("site_id") @db.Uuid
  type            PolicyType @default(privacy_policy)
  title           String     @default("Privacy Policy") @db.VarChar(255)
  contentHtml     String?    @map("content_html")
  contentMarkdown String?    @map("content_markdown")
  version         Int        @default(1)
  basedOnScanId   String?    @map("based_on_scan_id") @db.Uuid
  generatedAt     DateTime?  @map("generated_at")
  publishedAt     DateTime?  @map("published_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  basedOnScan Scan?           @relation(fields: [basedOnScanId], references: [id])
  versions    PolicyVersion[]

  @@unique([siteId, type])
  @@index([siteId])
  @@map("policies")
}

model PolicyVersion {
  id              String    @id @default(uuid()) @db.Uuid
  policyId        String    @map("policy_id") @db.Uuid
  version         Int
  contentHtml     String?   @map("content_html")
  contentMarkdown String?   @map("content_markdown")
  basedOnScanId   String?   @map("based_on_scan_id") @db.Uuid
  changeNote      String?   @map("change_note") @db.VarChar(500)
  createdBy       String?   @map("created_by") @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at")

  policy      Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  basedOnScan Scan?  @relation(fields: [basedOnScanId], references: [id])

  @@index([policyId, version(sort: Desc)])
  @@map("policy_versions")
}

// ─── Alerts ──────────────────────────────────────────────────────────────────

enum AlertType {
  new_tracker
  compliance_drop
  scan_failed
  policy_outdated
  dsar_deadline
  pia_required
  vendor_risk
}

model Alert {
  id        String    @id @default(uuid()) @db.Uuid
  siteId    String?   @map("site_id") @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  type      AlertType
  title     String    @db.VarChar(500)
  message   String
  severity  Severity
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  site Site?        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, readAt])
  @@map("alerts")
}

// ─── DSAR Management ─────────────────────────────────────────────────────────

enum DsarType {
  access
  deletion
  rectification
  portability
  opt_out
  restrict_processing
}

enum DsarStatus {
  received
  identity_verified
  processing
  data_collected
  review
  fulfilled
  rejected
  appealed
}

model DsarRequest {
  id              String     @id @default(uuid()) @db.Uuid
  orgId           String     @map("org_id") @db.Uuid
  siteId          String?    @map("site_id") @db.Uuid
  requestType     DsarType   @map("request_type")
  status          DsarStatus @default(received)
  jurisdiction    String     @db.VarChar(20)

  // Requester info
  requesterName   String     @map("requester_name") @db.VarChar(255)
  requesterEmail  String     @map("requester_email") @db.VarChar(255)
  requesterPhone  String?    @map("requester_phone") @db.VarChar(50)
  verificationId  String?    @map("verification_id")

  // Deadlines
  receivedAt      DateTime   @default(now()) @map("received_at")
  dueDate         DateTime   @map("due_date")
  extensionDays   Int        @default(0) @map("extension_days")

  // AI processing
  aiSummary       String?    @map("ai_summary") @db.Text
  dataLocations   Json?      @map("data_locations")
  responsePackage Json?      @map("response_package")

  // Audit trail
  notes           String?    @db.Text
  fulfilledAt     DateTime?  @map("fulfilled_at")
  rejectedReason  String?    @map("rejected_reason") @db.Text

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  org        Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  site       Site?          @relation(fields: [siteId], references: [id])
  activities DsarActivity[]

  @@index([orgId, status])
  @@index([orgId, dueDate])
  @@map("dsar_requests")
}

model DsarActivity {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @map("request_id") @db.Uuid
  action    String   @db.VarChar(100)
  details   Json?
  actor     String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  request DsarRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@map("dsar_activities")
}

// ─── Privacy Impact Assessments ──────────────────────────────────────────────

enum AssessmentStatus {
  draft
  in_progress
  ai_review
  human_review
  approved
  rejected
  archived
}

enum RiskLevel {
  low
  medium
  high
  critical
}

model Assessment {
  id           String           @id @default(uuid()) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  title        String           @db.VarChar(500)
  description  String?          @db.Text
  projectType  String           @map("project_type") @db.VarChar(100)
  status       AssessmentStatus @default(draft)
  riskLevel    RiskLevel?       @map("risk_level")

  // AI-powered assessment
  questions    Json?
  answers      Json?
  riskAnalysis Json?            @map("risk_analysis")
  aiReport     String?          @map("ai_report") @db.Text
  mitigations  Json?

  // Review
  reviewedBy   String?          @map("reviewed_by") @db.VarChar(255)
  reviewNotes  String?          @map("review_notes") @db.Text
  approvedAt   DateTime?        @map("approved_at")

  assignedToUserId String? @map("assigned_to_user_id") @db.Uuid

  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  org        Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedTo User?                @relation("AssessmentAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  activities AssessmentActivity[]

  @@index([orgId, status])
  @@index([assignedToUserId])
  @@map("assessments")
}

/// Append-only trail for PIA lifecycle (assignment, AI steps, review).
model AssessmentActivity {
  id           String   @id @default(uuid()) @db.Uuid
  assessmentId String   @map("assessment_id") @db.Uuid
  action       String   @db.VarChar(100)
  details      Json?
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  actor      User?      @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([assessmentId, createdAt(sort: Desc)])
  @@map("assessment_activities")
}

// ─── Data Governance ─────────────────────────────────────────────────────────

enum DataStoreType {
  database
  api
  file_storage
  saas_app
  crm
  analytics
  email_platform
  cdn
  payment_processor
  other
}

enum DataSensitivity {
  public
  internal
  confidential
  restricted
  pii
  sensitive_pii
}

model DataStore {
  id              String         @id @default(uuid()) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  name            String         @db.VarChar(255)
  type            DataStoreType
  provider        String?        @db.VarChar(100)
  location        String?        @db.VarChar(100)
  description     String?        @db.Text

  // Data classification (AI-generated)
  dataTypes       Json?          @map("data_types")
  sensitivity     DataSensitivity @default(internal)
  piiFields       Json?          @map("pii_fields")
  recordCount     Int?           @map("record_count")

  // Connection (for DSAR agent data discovery)
  connectionType  String?        @map("connection_type") @db.VarChar(50)
  connectionConfig Json?         @map("connection_config")
  lastSyncedAt    DateTime?      @map("last_synced_at")

  status          String         @default("active") @db.VarChar(20)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sourceFlows  DataFlow[]   @relation("sourceFlows")
  targetFlows  DataFlow[]   @relation("targetFlows")

  @@index([orgId, type])
  @@map("data_stores")
}

model DataFlow {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  sourceId     String   @map("source_id") @db.Uuid
  targetId     String   @map("target_id") @db.Uuid

  dataTypes    Json?    @map("data_types")
  purpose      String?  @db.VarChar(500)
  legalBasis   String?  @map("legal_basis") @db.VarChar(100)
  crossBorder  Boolean  @default(false) @map("cross_border")

  discoveredBy String?  @map("discovered_by") @db.VarChar(50)
  confidence   Float?
  verified     Boolean  @default(false)

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  source DataStore    @relation("sourceFlows", fields: [sourceId], references: [id], onDelete: Cascade)
  target DataStore    @relation("targetFlows", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@map("data_flows")
}

model Vendor {
  id               String    @id @default(uuid()) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  name             String    @db.VarChar(255)
  category         String    @db.VarChar(100)
  website          String?   @db.VarChar(500)
  dpaUrl           String?   @map("dpa_url") @db.VarChar(500)
  privacyPolicyUrl String?   @map("privacy_policy_url") @db.VarChar(500)
  subProcessors    Json?     @map("sub_processors")

  dataShared       Json?     @map("data_shared")
  purposes         Json?
  legalBasis       String?   @map("legal_basis") @db.VarChar(100)

  riskLevel        RiskLevel?  @map("risk_level")
  complianceStatus String?   @map("compliance_status") @db.VarChar(50)
  lastReviewedAt   DateTime? @map("last_reviewed_at")

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
  @@map("vendors")
}

// ─── Preference Management ───────────────────────────────────────────────────

model PreferenceCenter {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  siteId          String?   @map("site_id") @db.Uuid
  name            String    @db.VarChar(255)
  config          Json      @default("{}")
  publishedConfig Json?     @map("published_config")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  /// Optional HTTPS URL for preference subscription updates (HMAC-signed POST JSON).
  privacyWebhookUrl    String? @map("privacy_webhook_url") @db.VarChar(2048)
  privacyWebhookSecret String? @map("privacy_webhook_secret") @db.VarChar(255)

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  site        Site?            @relation(fields: [siteId], references: [id])
  preferences UserPreference[]

  @@map("preference_centers")
}

model UserPreference {
  id          String   @id @default(uuid()) @db.Uuid
  centerId    String   @map("center_id") @db.Uuid
  externalId  String?  @map("external_id") @db.VarChar(255)
  email       String?  @db.VarChar(255)
  preferences Json
  source      String   @default("manual") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  center PreferenceCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@index([centerId, email])
  @@index([centerId, externalId])
  @@map("user_preferences")
}

// ─── Agent System ────────────────────────────────────────────────────────────

enum AgentType {
  scanner
  dsar_processor
  policy_generator
  compliance_monitor
  data_mapper
  pia_assessor
  vendor_reviewer
}

enum AgentRunStatus {
  queued
  running
  completed
  failed
  cancelled
}

model AgentRun {
  id          String         @id @default(uuid()) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  agentType   AgentType      @map("agent_type")
  trigger     String         @db.VarChar(50)
  status      AgentRunStatus @default(queued)

  input       Json?
  output      Json?
  logs        Json?
  tokensUsed  Int            @default(0) @map("tokens_used")
  costCents   Int            @default(0) @map("cost_cents")

  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, agentType])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("agent_runs")
}

// ─── Webhook Subscriptions (API v1) ──────────────────────────────────────────

model WebhookSubscription {
  id        String    @id @default(uuid()) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  url       String    @db.VarChar(2048)
  secret    String    @db.VarChar(255)
  events    String[]
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("webhook_subscriptions")
}

// ─── Integrations (Phase B — Nango connectors) ──────────────────────────────

enum IntegrationProvider {
  salesforce
  hubspot
  shopify
}

enum IntegrationStatus {
  connected
  disconnected
  error
  syncing
}

model Integration {
  id              String             @id @default(uuid()) @db.Uuid
  orgId           String             @map("org_id") @db.Uuid
  provider        IntegrationProvider
  status          IntegrationStatus  @default(disconnected)

  /// Nango connection ID — used to fetch tokens
  nangoConnectionId String?          @map("nango_connection_id") @db.VarChar(255)

  /// Provider-specific config (e.g. Salesforce instance URL, Shopify store domain)
  config          Json?

  lastSyncAt      DateTime?          @map("last_sync_at")
  lastSyncError   String?            @map("last_sync_error") @db.Text
  syncedRecords   Int                @default(0) @map("synced_records")

  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@unique([orgId, provider])
  @@map("integrations")
}

model SyncLog {
  id            String   @id @default(uuid()) @db.Uuid
  integrationId String   @map("integration_id") @db.Uuid
  action        String   @db.VarChar(100)
  recordsCount  Int      @default(0) @map("records_count")
  durationMs    Int?     @map("duration_ms")
  error         String?  @db.Text
  details       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt(sort: Desc)])
  @@map("sync_logs")
}
