{
  "name": "custodia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "dev": "next dev --webpack",
    "build": "next build",
    "postbuild": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && (cp .env.local .next/standalone/.env 2>/dev/null || true)",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit -p tsconfig.ci.json",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate-deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "db:create-local-test-user": "tsx scripts/create-local-test-user.ts",
    "inventory-worker": "tsx src/workers/inventory-workers.ts",
    "scanner:dev": "tsx watch scanner/src/index.ts",
    "scanner:build": "tsup scanner/src/index.ts --format esm --out-dir scanner/dist --external playwright --external chromium-bidi",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@nangohq/node": "^0.69.47",
    "@prisma/client": "^6.5.0",
    "@sentry/nextjs": "^10.49.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.60.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.14.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.4.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.0",
    "sanitize-html": "^2.17.3",
    "stripe": "^17.7.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "prisma": "^6.5.0",
    "tailwindcss": "^4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
